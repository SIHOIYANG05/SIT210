#include <WiFiNINA.h>
#include <ThingSpeak.h>
#include <Wire.h>
#include <BH1750.h>
#include <DHT.h>
#include "secrets.h"

char ssid[] = SECRET_SSID;
char pass[] = SECRET_PASS;
WiFiClient client;

unsigned long channelID =  3307517;
const char *writeAPIKey = SECRET_APIKEY;

#define DHTPIN 10
#define DHTTYPE DHT11
DHT dht(DHTPIN, DHTTYPE);

BH1750 lightMeter;

void connectWiFi() {
  while (WiFi.status() != WL_CONNECTED) {
    Serial.print("Connecting to WiFi...");
    WiFi.begin(ssid, pass);
    delay(5000);
  }
  Serial.println("Connected to WiFi");
}

float readTemperature() {
  float temp = dht.readTemperature();

  if (isnan(temp)) {
    Serial.println("DHT11 read failed");
    return -1;
  }

  return temp;
}

float readLight() {
  float lux = lightMeter.readLightLevel();
  return lux;
}

void displayData(float temperature, float lightLevel) {
  Serial.print("Temperature: ");
  Serial.print(temperature);
  Serial.println(" C");

  Serial.print("Light Level: ");
  Serial.print(lightLevel);
  Serial.println(" lux");

  Serial.println("----------------------");
}

void sendToThingSpeak(float temperature, float lightLevel) {
  ThingSpeak.setField(1, temperature);
  ThingSpeak.setField(2, lightLevel);

  int result = ThingSpeak.writeFields(channelID, writeAPIKey);

  if (result == 200) {
    Serial.println("Data sent to ThingSpeak");
  } else {
    Serial.print("ThingSpeak error: ");
    Serial.println(result);
  }
}

void setup() {
  Serial.begin(9600);
  delay(1000);

  dht.begin();
  delay(2000);

  Wire.begin();
  lightMeter.begin();

  connectWiFi();
  ThingSpeak.begin(client);
}

void loop() {
  float temperature = readTemperature();
  float lightLevel = readLight();

  displayData(temperature, lightLevel);

  if (temperature != -1) {
    sendToThingSpeak(temperature, lightLevel);
  } else {
    Serial.println("Invalid temperature reading. Data not sent.");
  }

  delay(30000);
}

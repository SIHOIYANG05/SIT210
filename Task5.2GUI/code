import tkinter as tk
import RPi.GPIO as GPIO
 
GPIO.setmode(GPIO.BCM)
 
living = 18
bathroom = 27
closet = 22
 
GPIO.setup(living, GPIO.OUT)
GPIO.setup(bathroom, GPIO.OUT)
GPIO.setup(closet, GPIO.OUT)
 
living_pwm = GPIO.PWM(living, 1000)
living_pwm.start(0)  
 
def select_room():
    living_pwm.ChangeDutyCycle(0)
    GPIO.output(bathroom, False)
    GPIO.output(closet, False)
 
    if choice.get() == 1:
        living_pwm.ChangeDutyCycle(intensity.get())
    elif choice.get() == 2:
        GPIO.output(bathroom, True)
    elif choice.get() == 3:
        GPIO.output(closet, True)
 
def change_intensity(value):
    if choice.get() == 1:
        living_pwm.ChangeDutyCycle(float(value))
 
def exit_program():
    living_pwm.stop()
    GPIO.cleanup()
    root.destroy()
 
root = tk.Tk()
root.title("Smart Light Control")
 
choice = tk.IntVar()
intensity = tk.DoubleVar(value=50)  
 
tk.Label(root, text="Select Room").pack()
 
tk.Radiobutton(root, text="Living Room", variable=choice, value=1, command=select_room).pack()
tk.Radiobutton(root, text="Bathroom", variable=choice, value=2, command=select_room).pack()
tk.Radiobutton(root, text="Closet", variable=choice, value=3, command=select_room).pack()
 
tk.Label(root, text="Living Room Intensity").pack()
tk.Scale(root, from_=0, to=100, orient=tk.HORIZONTAL, variable=intensity,
         command=change_intensity, length=250).pack()
 
tk.Button(root, text="Exit", command=exit_program).pack()

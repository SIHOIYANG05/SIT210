#include <WiFiNINA.h>
#include <PubSubClient.h>
#include "arduino_secrets.h"   

char ssid[] = SECRET_SSID;
char pass[] = SECRET_PASS;

const char* mqttServer = "broker.emqx.io";
const int mqttPort = 1883;

WiFiClient wifiClient;
PubSubClient client(wifiClient);

const int trigPin = 8;
const int echoPin = 7;

const int ledHallway = 5;
const int ledBathroom = 11;

long duration;
float distance;

unsigned long lastDetectTime = 0;
const unsigned long cooldown = 1500;

String userName = "Sean";   

void connectWiFi()
{
  Serial.print("Connecting to WiFi");

  while (WiFi.begin(ssid, pass) != WL_CONNECTED)
  {
    Serial.print(".");
    delay(3000);
  }

  Serial.println("\nWiFi connected");
}

void reconnectMQTT()
{
  while (!client.connected())
  {
    Serial.print("Connecting to MQTT...");

    String clientId = "Nano33-" + String(random(1000, 9999));

    if (client.connect(clientId.c_str()))
    {
      Serial.println("connected");

      client.subscribe("ES/Wave");
      client.subscribe("ES/Pat");
    }
    else
    {
      Serial.print("failed, rc=");
      Serial.println(client.state());
      delay(3000);
    }
  }
}

float readDistance()
{
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duration = pulseIn(echoPin, HIGH);
  return duration * 0.0343 / 2.0;
}

void callback(char* topic, byte* payload, unsigned int length)
{
  String message = "";

  for (unsigned int i = 0; i < length; i++)
  {
    message += (char)payload[i];
  }

  Serial.print("Topic: ");
  Serial.println(topic);
  Serial.print("Message: ");
  Serial.println(message);

  if (String(topic) == "ES/Wave")
  {
    digitalWrite(ledHallway, HIGH);
    digitalWrite(ledBathroom, HIGH);
  }
  else if (String(topic) == "ES/Pat")
  {
    digitalWrite(ledHallway, LOW);
    digitalWrite(ledBathroom, LOW);
  }
}

void setup()
{
  Serial.begin(9600);
  delay(2000);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  pinMode(ledHallway, OUTPUT);
  pinMode(ledBathroom, OUTPUT);

  digitalWrite(ledHallway, LOW);
  digitalWrite(ledBathroom, LOW);

  connectWiFi();

  client.setServer(mqttServer, mqttPort);
  client.setCallback(callback);
}

void loop()
{
  if (WiFi.status() != WL_CONNECTED)
    connectWiFi();

  if (!client.connected())
    reconnectMQTT();

  client.loop();

  distance = readDistance();

  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.println(" cm");

  if (millis() - lastDetectTime > cooldown)
  {
    if (distance > 5 && distance <= 15)
    {
      String msg = userName + " WAVE";
      client.publish("ES/Wave", msg.c_str());
      lastDetectTime = millis();
    }
    else if (distance > 0 && distance <= 5)
    {
      String msg = userName + " PAT";
      client.publish("ES/Pat", msg.c_str());
      lastDetectTime = millis();
    }
  }

  delay(300);
}
